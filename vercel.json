{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "mobile.html", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "service-worker.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/mobile", "dest": "/mobile.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
